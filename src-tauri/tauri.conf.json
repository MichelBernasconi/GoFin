{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "GoFin",
  "version": "0.1.0",
  "identifier": "com.gofin.app",
  "build": {
    "frontendDist": "../frontend/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm --prefix ../frontend run dev",
    "beforeBuildCommand": "npm --prefix ../frontend run build"
  },
  "app": {
    "windows": [
      {
        "title": "GoFin - Quantara GUI",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png"
    ],
    "externalBin": [
      "binaries/gofin-bridge"
    ]
  }
}
